# Секреты для Supabase Edge Functions (register-send-code, register-verify).
# Скопируйте в .env и заполните. Не коммитьте .env.
# В облаке: Dashboard → Project Settings → Edge Functions → Secrets
# или: supabase secrets set --env-file .env

# --- Обязательно для edge functions ---

# URL проекта (как в assets/js/config.js)
SUPABASE_URL=https://ppehttbtrlavnrytoweu.supabase.co

# Service role — только на сервере, НЕ в config.js и НЕ в браузере
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Одинаковый «перец» в register-send-code и register-verify (длинная случайная строка)
REGISTRATION_PEPPER=change-me-to-long-random-string

# --- Отправка кода на почту (нужен хотя бы ОДИН способ) ---

# Вариант A (рекомендуется без Resend): Brevo HTTP API — https://www.brevo.com
# API Keys → Create → v3 key. Подтвердите отправителя в Senders.
BREVO_API_KEY=
BREVO_FROM_EMAIL=SPARK <noreply@yourdomain.com>

# Вариант B: SMTP (те же логин/пароль, что в Dashboard → Authentication → SMTP Settings)
# На Edge Functions порты 25/465/587 часто недоступны — у провайдера укажите 2525 или используйте Brevo API.
SMTP_HOSTNAME=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=SPARK <noreply@yourdomain.com>

# Вариант C (позже): Resend — https://resend.com
RESEND_API_KEY=YOUR_RESEND_API_KEY_HERE
RESEND_FROM_EMAIL=SPARK <onboarding@resend.dev>

# --- Только локальная отладка (НЕ для друзей на других устройствах) ---

# true — вернуть dev_code в JSON (toast в приложении). В проде оставьте false.
ALLOW_DEV_REGISTRATION_CODES=false
